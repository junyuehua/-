    "x": 143126,
    "y": 3104,
    "tags": [
      "物件"
    ],
    "tier": "场景",
    "title_zh": "石碾",
    "title_en": "",
    "body_zh": "牲畜拉着碾转动，帮助谷物脱掉外壳。",
    "body_en": ""
  },
  {
    "id": 10,
    "x": 143384,
    "y": 3646,
    "tags": [
      "动物"
    ],
    "tier": "场景",
    "title_zh": "禽畜",
    "title_en": "",
    "body_zh": "院子一角有饲养的禽类和一头猪？正在往圈里拱",
    "body_en": ""
  },
  {
    "id": 11,
    "x": 144277,
    "y": 1772,
    "tags": [
      "物件"
    ],
    "tier": "细节",
    "title_zh": "鸟窝",
    "title_en": "",
    "body_zh": "褪去树叶的枝杈上零星可见几处鸟窝，画者对生活细节的观察细致入微。",
    "body_en": ""
  },
  {
    "id": 12,
    "x": 128315,
    "y": 6223,
    "tags": [
      "人物"
    ],
    "tier": "场景",
    "title_zh": "远行的队伍",
    "title_en": "",
    "body_zh": "两位骑驴的人，看似是一对夫妻。仆人肩挑着行李，似乎路途不近。",
    "body_en": ""
  },
  {
    "id": 13,
    "x": 125570,
    "y": 4263,
    "tags": [
      "人物"
    ],
    "tier": "场景",
    "title_zh": "老妇与小童",
    "title_en": "",
    "body_zh": "妇人见旁边失控的奔马，赶紧去护着自己的孩子。",
    "body_en": ""
  },
  {
    "id": 14,
    "x": 124493,
    "y": 2786,
    "tags": [
      "动物"
    ],
    "tier": "场景",
    "title_zh": "看戏的牛",
    "title_en": "",
    "body_zh": "两头休息的牛也被这场追逐戏吸引了，纷纷看向事发地。",
    "body_en": ""
  },
  {
    "id": 15,
    "x": 123533,
    "y": 2799,
    "tags": [
      "物件"
    ],
    "tier": "场景",
    "title_zh": "摇篮",
    "title_en": "",
    "body_zh": "一位母亲正把婴儿从摇篮里抱了出来。",
    "body_en": ""
  },
  {
    "id": 16,
    "x": 122021,
    "y": 2799,
    "tags": [
      "动物"
    ],
    "tier": "场景",
    "title_zh": "受惊的毛驴",
    "title_en": "",
    "body_zh": "这匹被拴着的毛驴正非常不安地望向远处的追逐。反观离得更近的那一对水牛却显得非常淡定。",
    "body_en": ""
  },
  {
    "id": 17,
    "x": 144634,
    "y": 3480,
    "tags": [
      "植物"
    ],
    "tier": "场景",
    "title_zh": "榆树",
    "title_en": "",
    "body_zh": "房子旁边种植榆柳是古人的常态。陶渊明在诗中就有说：榆柳荫后檐，桃李罗堂前。",
    "body_en": ""
  },
  {
    "id": 18,
    "x": 147397,
    "y": 2724,
    "tags": [
      "植物"
    ],
    "tier": "场景",
    "title_zh": "柳树",
    "title_en": "",
    "body_zh": "房子旁边种植榆柳是古人的常态。陶渊明在诗中就有说：榆柳荫后檐，桃李罗堂前。",
    "body_en": ""
  },
  {
    "id": 19,
    "x": 130641,
    "y": 5274,
    "tags": [
      "植物"
    ],
    "tier": "场景",
    "title_zh": "断裂的树冠",
    "title_en": "",
    "body_zh": "仔细看能发现这棵柳树树冠彻底断裂了，看向断裂处能清楚看到后景。这惊险的一瞬被永远定格了。",
    "body_en": ""
  },
